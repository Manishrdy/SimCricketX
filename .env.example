# -----------------------------------------------------------------------------
# Exception -> GitHub Issue Automation (optional)
# -----------------------------------------------------------------------------
# Enable automatic GitHub issue creation after exception rows are committed.
GITHUB_ISSUE_ON_EXCEPTION_ENABLED=false

# Fine-grained PAT recommended. Minimum permissions:
# - Issues: Read and write
# For public repositories, classic token with `public_repo` also works.
GITHUB_TOKEN=your_github_token_here

# Repository in owner/repo format (example: octocat/Hello-World)
GITHUB_REPOSITORY=owner/repository

# Optional issue customization
GITHUB_ISSUE_TITLE_PREFIX=[Auto Exception]
GITHUB_ISSUE_LABELS=bug,auto-exception
GITHUB_ISSUE_ASSIGNEES=

# -----------------------------------------------------------------------------
# GitHub Webhook (PLAN-IR-001 Phase 3)
# -----------------------------------------------------------------------------
# Shared secret for validating inbound GitHub webhook deliveries.
# Configure the same value in: GitHub repo -> Settings -> Webhooks ->
#   Payload URL: https://<your-host>/webhooks/github/issues
#   Content type: application/json
#   Secret: (this value)
#   Events: "Issues" only
# Leave blank to disable inbound webhook processing entirely.
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Auction UX rollout (Module A)
# -----------------------------------------------------------------------------
# When true, finalized auction setup (status = auction_ready) becomes read-only
# until explicitly reopened by the organizer.
# Values: true/false, 1/0, yes/no, on/off
AUCTION_SIMPLIFIED_FLOW=false
