# -----------------------------------------------------------------------------
# Exception -> GitHub Issue Automation (optional)
# -----------------------------------------------------------------------------
# Enable automatic GitHub issue creation after exception rows are committed.
GITHUB_ISSUE_ON_EXCEPTION_ENABLED=false

# Fine-grained PAT recommended. Minimum permissions:
# - Issues: Read and write
# For public repositories, classic token with `public_repo` also works.
GITHUB_TOKEN=your_github_token_here

# Repository in owner/repo format (example: octocat/Hello-World)
GITHUB_REPOSITORY=owner/repository

# Optional issue customization
GITHUB_ISSUE_TITLE_PREFIX=[Auto Exception]
GITHUB_ISSUE_LABELS=bug,auto-exception
GITHUB_ISSUE_ASSIGNEES=
